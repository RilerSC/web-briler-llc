# Copy to .env locally. On Vercel: Project → Settings → Environment Variables.

# Required — from https://resend.com/api-keys
RESEND_API_KEY=

# Optional — defaults shown in src/lib/mail.ts
# Use a verified domain address after adding briler.net in Resend (recommended for production).
# RESEND_FROM=Briler <noreply@briler.net>
# RESEND_TO=info@briler.net
